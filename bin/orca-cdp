#!/usr/bin/env bash
# orca-cdp — discover the Chrome DevTools Protocol (CDP) endpoint(s) exposed by
# Orca's embedded Chromium. EACH open tab exposes its OWN endpoint on its own
# ephemeral port, so the set changes as you open/close tabs and across launches.
#
# Usage:
#   orca-cdp                 # base URL of the first CDP endpoint
#   orca-cdp --port|--ws|--json|--list|--export
#   orca-cdp --all           # one line per endpoint:  <baseUrl>  <pageUrl>
#   orca-cdp --match <regex> # base URL of the endpoint whose page URL matches
#   orca-cdp -q              # quiet: no diagnostics on stderr
#
# Exit codes: 0 found, 1 Orca not running, 2 running but no CDP endpoint / no match.

set -euo pipefail

QUIET=0; MODE="url"; MATCH=""
while [ $# -gt 0 ]; do
  case "$1" in
    --port) MODE=port ;; --ws) MODE=ws ;; --json) MODE=json ;; --list) MODE=list ;;
    --export) MODE=export ;; --all) MODE=all ;;
    --match) MATCH="${2:-}"; shift ;;
    -q|--quiet) QUIET=1 ;;
    -h|--help) sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "orca-cdp: unknown arg '$1'" >&2; exit 64 ;;
  esac
  shift
done
log() { [ "$QUIET" -eq 1 ] || echo "orca-cdp: $*" >&2; }

# 1. Every Orca-owned listening TCP port.
PORTS="$(lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null | grep -i orca \
          | awk '{n=split($9,a,":"); print a[n]}' | sort -un || true)"
if [ -z "$PORTS" ]; then
  if pgrep -x Orca >/dev/null 2>&1 || pgrep -if '/Orca' >/dev/null 2>&1; then
    log "Orca is running but has no listening TCP ports."; exit 2
  fi
  log "Orca does not appear to be running."; exit 1
fi

# 2. Keep ports that answer the CDP probe; record port + page URL + ws URL.
EPS=""
for port in $PORTS; do
  list="$(curl -fs --max-time 2 "http://127.0.0.1:$port/json/list" 2>/dev/null || true)"
  case "$list" in
    *webSocketDebuggerUrl*)
      pageUrl="$(printf '%s' "$list" | sed -n 's/.*"url":"\([^"]*\)".*/\1/p' | head -1)"
      wsUrl="$(printf '%s' "$list" | sed -n 's/.*"webSocketDebuggerUrl":"\([^"]*\)".*/\1/p' | head -1)"
      EPS="${EPS}${port}"$'\t'"${pageUrl}"$'\t'"${wsUrl}"$'\n'
      ;;
  esac
done
if [ -z "$EPS" ]; then
  log "Orca running but no port answered the CDP probe (tried: $(echo $PORTS | tr '\n' ' '))."; exit 2
fi

emit_one() { # $1=port $2=pageUrl $3=wsUrl
  case "$MODE" in
    port)   echo "$1" ;;
    url)    echo "http://127.0.0.1:$1" ;;
    ws)     echo "$3" ;;
    json)   curl -fs --max-time 2 "http://127.0.0.1:$1/json/version" 2>/dev/null; echo ;;
    list)   curl -fs --max-time 2 "http://127.0.0.1:$1/json/list" 2>/dev/null; echo ;;
    export) echo "export ORCA_CDP_URL=http://127.0.0.1:$1" ;;
  esac
}

# 3a. --all: list every endpoint.
if [ "$MODE" = all ]; then
  while IFS=$'\t' read -r port pageUrl wsUrl; do
    [ -n "$port" ] && echo "http://127.0.0.1:$port  $pageUrl"
  done <<< "$EPS"
  exit 0
fi

# 3b. --match <regex>: the endpoint whose page URL matches.
if [ -n "$MATCH" ]; then
  while IFS=$'\t' read -r port pageUrl wsUrl; do
    [ -z "$port" ] && continue
    if printf '%s' "$pageUrl" | grep -Eq "$MATCH"; then
      log "matched $MATCH on port $port ($pageUrl)"; emit_one "$port" "$pageUrl" "$wsUrl"; exit 0
    fi
  done <<< "$EPS"
  log "no CDP endpoint matches /$MATCH/ (tabs: $(printf '%s' "$EPS" | cut -f2 | tr '\n' ' '))"; exit 2
fi

# 3c. default: the first endpoint.
IFS=$'\t' read -r port pageUrl wsUrl <<< "$(printf '%s' "$EPS" | head -1)"
log "found CDP on port $port ($pageUrl)"
emit_one "$port" "$pageUrl" "$wsUrl"
