{
  "name": "orca-playwright-bridge",
  "version": "1.5.2",
  "description": "Drive the Orca app's embedded Chromium browser with Playwright (or raw CDP) by bridging its internal Chrome DevTools Protocol proxy.",
  "license": "MIT",
  "bin": {
    "orca-cdp": "bin/orca-cdp",
    "orca-playwright-bridge": "bin/cli.js"
  },
  "main": "lib/orca-pw-bridge.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./lib/orca-pw-bridge.js"
    },
    "./bridge": {
      "types": "./index.d.ts",
      "default": "./lib/orca-pw-bridge.js"
    },
    "./connect": {
      "types": "./connect.d.ts",
      "default": "./lib/orca-connect.js"
    },
    "./maestro": {
      "types": "./maestro.d.ts",
      "default": "./lib/orca-maestro.js"
    }
  },
  "files": [
    "bin/",
    "lib/",
    "commands/",
    "skills/",
    ".claude-plugin/",
    "index.d.ts",
    "connect.d.ts",
    "maestro.d.ts",
    "install.sh",
    "get.sh",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "demo": "node demo/server.js",
    "smoke:cdp": "bin/orca-cdp",
    "smoke:pw": "node lib/orca-pw-bridge.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagarpalsapure/orca-playwright-bridge.git"
  },
  "homepage": "https://github.com/sagarpalsapure/orca-playwright-bridge#readme",
  "bugs": {
    "url": "https://github.com/sagarpalsapure/orca-playwright-bridge/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "chrome-remote-interface": "^0.33.3",
    "playwright-core": "^1.61.1",
    "ws": "^8.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "orca",
    "playwright",
    "cdp",
    "chrome-devtools-protocol",
    "browser-automation"
  ]
}
