{
  "name": "orca-playwright-bridge",
  "version": "1.0.3",
  "description": "Drive the Orca app's embedded Chromium browser with Playwright (or raw CDP) by bridging its internal Chrome DevTools Protocol proxy.",
  "license": "MIT",
  "bin": {
    "orca-cdp": "bin/orca-cdp"
  },
  "main": "lib/orca-pw-bridge.js",
  "exports": {
    ".": "./lib/orca-pw-bridge.js",
    "./bridge": "./lib/orca-pw-bridge.js",
    "./connect": "./lib/orca-connect.js"
  },
  "files": [
    "bin/",
    "lib/",
    "commands/",
    "install.sh",
    "README.md"
  ],
  "scripts": {
    "test": "node --test --test-concurrency=1 \"test/**/*.test.js\"",
    "smoke:cdp": "bin/orca-cdp",
    "smoke:pw": "node lib/orca-pw-bridge.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagarpalsapure/orca-playwright-bridge.git"
  },
  "homepage": "https://github.com/sagarpalsapure/orca-playwright-bridge#readme",
  "bugs": {
    "url": "https://github.com/sagarpalsapure/orca-playwright-bridge/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "chrome-remote-interface": "^0.33.3",
    "playwright-core": "^1.52.0",
    "ws": "^8.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "orca",
    "playwright",
    "cdp",
    "chrome-devtools-protocol",
    "browser-automation"
  ]
}
